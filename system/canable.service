[Unit]
Description=CANable2 Interface Setup
BindsTo=dev-canable2.device
After=dev-canable2.device

[Service]
Type=forking
# Spawn the daemon using the persistent symlink created by udev
ExecStart=/usr/bin/slcand -o -s6 -t hw -S 3000000 /dev/canable2 can0
# Wait briefly to ensure the network interface is fully registered
ExecStartPost=/usr/bin/sleep 1
# Bring the interface up
ExecStartPost=/usr/sbin/ip link set up can0

[Install]
WantedBy=multi-user.target
